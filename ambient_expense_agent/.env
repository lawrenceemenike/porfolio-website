# ==========================================
# Authentication Configuration
# ==========================================

# OPTION 1: Google AI Studio (Default)
# Get your API key here: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=REPLACE_WITH_YOUR_API_KEY

# OPTION 2: Google Cloud Vertex AI
# To use Vertex AI, comment out Option 1 and uncomment the lines below.
# You will also need to authenticate your local environment using the gcloud CLI:
# Run: `gcloud auth application-default login`
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# GOOGLE_CLOUD_LOCATION=us-central1